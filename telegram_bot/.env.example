# Copy this file to /etc/p2pool-bot.env (chmod 600, chown ubuntu)
# NEVER commit this file with real values.
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
LOCAL_EVENT_PORT=19349
P2POOL_API_URL=http://127.0.0.1:9348
SUBSCRIPTIONS_FILE=/home/ubuntu/Github/p2pool/telegram_bot/subscriptions.json
# BROADCAST_CHANNEL_ID=-100xxxxxxxxxx

# Set to true to allow only one Telegram subscriber per BCH address.
# Default (unset / false) allows multiple subscribers per address.
# ONE_SUB_PER_ADDRESS=false

# Outbound proxy for Telegram API access — uncomment and set when the
# bot host can't reach api.telegram.org directly (regional blocks,
# restricted egress).  Use http://, https://, socks5:// or socks5h://.
# Embed credentials inline if needed: scheme://user:pass@host:port.
# SOCKS support requires python-telegram-bot[socks] (already pinned in
# requirements.txt).  Leave both unset for direct connection.
# BOT_PROXY=socks5h://127.0.0.1:1080
# BOT_PROXY_GET_UPDATES=socks5h://127.0.0.1:1080

# ── Bot implementation ─────────────────────────────────────────────────────
# Pick which bot library to use:
#   ptb     — python-telegram-bot, Bot API over HTTPS (default).  Works
#             with HTTP/HTTPS/SOCKS5 proxies (BOT_PROXY).
#   mtproto — Telethon, MTProto direct.  Additionally supports MTProto
#             Telegram-app proxies (proxytg.live, bella-cook.com, etc.)
#             via MTPROXY_HOST/PORT/SECRET.  Requires MTPROTO_API_ID
#             and MTPROTO_API_HASH from https://my.telegram.org/apps.
# BOT_IMPL=ptb

# ── MTProto-only settings (BOT_IMPL=mtproto) ───────────────────────────────
# Get these once at https://my.telegram.org/apps (sign in with the bot
# owner's personal Telegram account; the bot itself doesn't log in there).
# MTPROTO_API_ID=1234567
# MTPROTO_API_HASH=0123456789abcdef0123456789abcdef

# Optional: MTProto Telegram-app proxy.  When set, takes precedence over
# BOT_PROXY for the mtproto bot.  Secret hex = the secret string Telegram
# apps display when you tap a proxy entry (starts with ee… or dd…).
# MTPROXY_HOST=bella-cook.com
# MTPROXY_PORT=443
# MTPROXY_SECRET=ee1100000000000000000000000000000061706976302e7465616d2e7472616e73706f7274

# Deploy notes:
# - The install script creates a venv at Github/p2pool/bot-venv/ with bot deps.
# - p2pool-run.sh auto-adds --run-bot --bot-python .../bot-venv/bin/python3
#   when this file exists at /etc/p2pool-bot.env.
# - No separate systemd service for the bot is needed.
